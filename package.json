{
  "name": "lok-thoughts-page-arena",
  "version": "1.0.0",
  "description": "A page of Leon's thoughts connected to Are.na channel",
  "main": "src/worker.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build:dev-bundle": "wrangler deploy --dry-run --outdir .wrangler/tmp-bundle",
    "dev:prebuilt": "wrangler dev --no-bundle .wrangler/tmp-bundle/worker.js --port 8787 --show-interactive-dev-session=false"
  },
  "devDependencies": {
    "wrangler": "^4.70.0"
  },
  "keywords": [
    "cloudflare",
    "worker",
    "arena"
  ],
  "author": "Leon",
  "license": "MIT"
}
